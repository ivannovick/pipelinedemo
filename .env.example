# --- Ingest (Airflow DAG: gdrive_publish_to_stream) ---
GDRIVE_BUCKET_URL=gdrive://YOUR_FOLDER_OR_PATH/

# --- RabbitMQ Streams (publisher + Airflow batch consumer DAG) ---
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_VHOST=/
STREAM_NAME=pdf.jobs
# Durable consumer name (offset checkpointing on the broker)
STREAM_CONSUMER_NAME=pdf-processor
# next | first — same as before; used when subscribing each batch run
STREAM_READ_OFFSET=next
# Batch DAG pdf_stream_batch_consumer: max wall time per run (keep < 60 if schedule is 1 min)
STREAM_BATCH_POLL_SECONDS=50
STREAM_BATCH_MAX_MESSAGES=200

# --- Postgres (batch consumer DAG writes rows here) ---
POSTGRES_USER=pdfuser
POSTGRES_PASSWORD=pdfpass
POSTGRES_DB=pdfarchive
POSTGRES_PORT=5432

# --- Pipeline diagram (workflow-viz + API; Silver tables use this dbt schema) ---
WORKFLOW_VIZ_PORT=3456
# DBT_SCHEMA=dbt_analytics

# workflow-viz: GitHub base for DAG file links — use blob/.../dags (not tree/...) so each file opens correctly; no trailing slash
# Default in compose matches pipelinedemo; override for your fork:
# WORKFLOW_VIZ_DAG_SOURCE_BASE=https://github.com/ivannovick/pipelinedemo/blob/main/dags
# Optional Airflow UI link on the viz page (browser opens host port, e.g. after docker compose port map)
# WORKFLOW_VIZ_AIRFLOW_UI_URL=http://localhost:8080

# RabbitMQ management UI link (host browser; compose maps 15672)
# WORKFLOW_VIZ_RABBITMQ_UI_URL=http://localhost:15672

# If set, workflow-viz shows “Clear stream” and POST /api/stream/clear requires this secret (JSON body)
# WORKFLOW_VIZ_STREAM_RESET_SECRET=change-me

# --- dbt DAG (dbt_run_pdf_archive) schedule in minutes (default 60) ---
# DBT_RUN_SCHEDULE_MINUTES=60

# Optional: absolute path to ./data/pdfs on your PC — then Postgres column local_pc_archive_path stores full paths.
# If unset, local_pc_archive_path is repo-relative: data/pdfs/<filename>
# PDF_HOST_BASE_DIR=C:\Users\mail\OneDrive\Documents\airbyteapp\data\pdfs
