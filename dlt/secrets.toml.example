# ./dlt is mounted as /opt/airflow/.dlt in the Airflow container.
# Share your Drive folder with the service account email from the JSON key.
# See: https://dlthub.com/docs/dlt-ecosystem/verified-sources/filesystem/basic
#
# Preferred: put the downloaded GCP key JSON at ./dlt/service_account.json (gitignored).
# The DAG loads that file first; you can leave secrets.toml as comments-only.
#
# Fallback: TOML credentials below (do not paste the whole JSON blob as a value).
# client_email must be the service account (*.iam.gserviceaccount.com), not Gmail.

[sources.filesystem.credentials]
client_email = "your-sa@project.iam.gserviceaccount.com"
private_key = """-----BEGIN PRIVATE KEY-----
... paste key ...
-----END PRIVATE KEY-----
"""
project_id = "your-gcp-project-id"
